generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model alertas {
  id_alerta               BigInt                @id @default(autoincrement())
  id_tipo_alerta          BigInt
  id_corral               BigInt?
  id_nido                 BigInt?
  id_registro_temperatura BigInt?
  nivel                   String                @db.VarChar(20)
  titulo                  String                @db.VarChar(150)
  mensaje                 String
  estado                  String                @default("pendiente") @db.VarChar(20)
  fecha_generacion        DateTime              @default(now()) @db.Timestamp(6)
  resuelta_por            BigInt?
  fecha_resolucion        DateTime?             @db.Timestamp(6)
  corral                  corral?               @relation(fields: [id_corral], references: [id_corral], onDelete: NoAction, onUpdate: NoAction)
  nido                    nido?                 @relation(fields: [id_nido], references: [id_nido], onDelete: NoAction, onUpdate: NoAction)
  registro_temperatura    registro_temperatura? @relation(fields: [id_registro_temperatura], references: [id_registro_temperatura], onDelete: NoAction, onUpdate: NoAction)
  tipo_alerta             tipo_alerta           @relation(fields: [id_tipo_alerta], references: [id_tipo_alerta], onDelete: NoAction, onUpdate: NoAction)
  usuario                 usuario?              @relation(fields: [resuelta_por], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction)

  @@index([estado], map: "idx_alertas_estado")
  @@index([fecha_generacion], map: "idx_alertas_fecha")
}

model condicion_marea {
  id_condicion_marea BigInt     @id @default(autoincrement())
  nombre             String     @unique @db.VarChar(50)
  descripcion        String?
  eclosion           eclosion[]
}

model corral {
  id_corral         BigInt          @id @default(autoincrement())
  codigo            String          @unique @db.VarChar(50)
  ubicacion         String
  fecha_instalacion DateTime        @db.Timestamp(6)
  creado_por        BigInt
  id_tipo_corral    BigInt
  id_estado_corral  BigInt
  observaciones     String?
  fecha_creacion    DateTime        @default(now()) @db.Timestamp(6)
  alertas           alertas[]
  usuario           usuario         @relation(fields: [creado_por], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction)
  estado_corral     estado_corral   @relation(fields: [id_estado_corral], references: [id_estado_corral], onDelete: NoAction, onUpdate: NoAction)
  tipo_corral       tipo_corral     @relation(fields: [id_tipo_corral], references: [id_tipo_corral], onDelete: NoAction, onUpdate: NoAction)
  sector_corral     sector_corral[]

  @@index([id_estado_corral], map: "idx_corral_estado")
  @@index([id_tipo_corral], map: "idx_corral_tipo")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model detalle_temperatura {
  id_detalle_temperatura  BigInt               @id @default(autoincrement())
  id_registro_temperatura BigInt
  profundidad_cm          Decimal              @db.Decimal(5, 2)
  temperatura             Decimal              @db.Decimal(4, 2)
  orden_medicion          String?              @db.VarChar(50)
  registro_temperatura    registro_temperatura @relation(fields: [id_registro_temperatura], references: [id_registro_temperatura], onDelete: Cascade, onUpdate: NoAction)

  @@index([id_registro_temperatura], map: "idx_detalle_temperatura_registro")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model eclosion {
  id_eclosion                   BigInt          @id @default(autoincrement())
  id_nido                       BigInt          @unique
  fecha_hora_eclosion           DateTime        @db.Timestamp(6)
  neonatos_vivos_fuera_arena    Int?            @default(0)
  neonatos_muertos_fuera_arena  Int?            @default(0)
  neonatos_vivos_dentro_arena   Int?            @default(0)
  neonatos_muertos_dentro_arena Int?            @default(0)
  fecha_hora_liberacion         DateTime?       @db.Timestamp(6)
  id_condicion_marea            BigInt
  responsable_liberacion        String?         @db.VarChar(150)
  observaciones                 String?
  registrado_por                BigInt
  fecha_registro                DateTime        @default(now()) @db.Timestamp(6)
  condicion_marea               condicion_marea @relation(fields: [id_condicion_marea], references: [id_condicion_marea], onDelete: NoAction, onUpdate: NoAction)
  nido                          nido            @relation(fields: [id_nido], references: [id_nido], onDelete: Cascade, onUpdate: NoAction)
  usuario                       usuario         @relation(fields: [registrado_por], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction)
}

model especie {
  id_especie        BigInt  @id @default(autoincrement())
  nombre_comun      String  @unique @db.VarChar(100)
  nombre_cientifico String  @unique @db.VarChar(150)
  descripcion       String?
  nido              nido[]
}

model estado_corral {
  id_estado_corral BigInt   @id @default(autoincrement())
  nombre           String   @unique @db.VarChar(50)
  descripcion      String?
  corral           corral[]
}

model estado_nido {
  id_estado_nido BigInt  @id @default(autoincrement())
  nombre         String  @unique @db.VarChar(50)
  descripcion    String?
  nido           nido[]
}

model estado_usuario {
  id_estado_usuario BigInt    @id @default(autoincrement())
  nombre            String    @unique @db.VarChar(50)
  descripcion       String?
  usuario           usuario[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model exhumacion {
  id_exhumacion            BigInt           @id @default(autoincrement())
  id_nido                  BigInt           @unique
  realizado_por            BigInt
  fecha_hora_exhumacion    DateTime         @db.Timestamp(6)
  huevos_sin_embrion       Int?             @default(0)
  embriones_muertos        Int?             @default(0)
  huevos_no_eclosionados   Int?             @default(0)
  neonatos_muertos_en_nido Int?             @default(0)
  evidencia_depredacion    Boolean?         @default(false)
  id_tipo_depredador       BigInt?
  cascarones_eclosionados  Int?             @default(0)
  observaciones            String?
  fecha_registro           DateTime         @default(now()) @db.Timestamp(6)
  nido                     nido             @relation(fields: [id_nido], references: [id_nido], onDelete: Cascade, onUpdate: NoAction)
  tipo_depredador          tipo_depredador? @relation(fields: [id_tipo_depredador], references: [id_tipo_depredador], onDelete: NoAction, onUpdate: NoAction)
  usuario                  usuario          @relation(fields: [realizado_por], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model nido {
  id_nido            BigInt        @id @default(autoincrement())
  codigo_nido        String        @unique @db.VarChar(50)
  id_especie         BigInt
  registrado_por     BigInt
  id_sector_corral   BigInt
  fecha_hora_desove  DateTime      @db.Timestamp(6)
  fecha_hora_siembra DateTime      @db.Timestamp(6)
  procedencia_exacta String?
  largo_caparazon    Decimal?      @db.Decimal(5, 2)
  ancho_caparazon    Decimal?      @db.Decimal(5, 2)
  profundidad_nido   Decimal       @db.Decimal(5, 2)
  cantidad_huevos    Int
  id_estado_nido     BigInt
  fecha_creacion     DateTime      @default(now()) @db.Timestamp(6)
  alertas            alertas[]
  eclosion           eclosion?
  exhumacion         exhumacion?
  especie            especie       @relation(fields: [id_especie], references: [id_especie], onDelete: NoAction, onUpdate: NoAction)
  estado_nido        estado_nido   @relation(fields: [id_estado_nido], references: [id_estado_nido], onDelete: NoAction, onUpdate: NoAction)
  sector_corral      sector_corral @relation(fields: [id_sector_corral], references: [id_sector_corral], onDelete: NoAction, onUpdate: NoAction)
  usuario            usuario       @relation(fields: [registrado_por], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction)

  @@index([id_especie], map: "idx_nido_especie")
  @@index([id_sector_corral], map: "idx_nido_sector")
}

model recuperacion_password {
  id_recuperacion BigInt   @id @default(autoincrement())
  id_usuario      BigInt
  codigo          String   @db.VarChar(100)
  expiracion      DateTime @db.Timestamp(6)
  usado           Boolean  @default(false)
  usuario         usuario  @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade, onUpdate: NoAction)

  @@index([id_usuario], map: "idx_recuperacion_password_usuario")
}

model registro_temperatura {
  id_registro_temperatura BigInt                @id @default(autoincrement())
  id_sector_corral        BigInt
  fecha_hora_medicion     DateTime              @db.Timestamp(6)
  observaciones           String?
  registrado_por          BigInt
  fecha_registro          DateTime              @default(now()) @db.Timestamp(6)
  alertas                 alertas[]
  detalle_temperatura     detalle_temperatura[]
  sector_corral           sector_corral         @relation(fields: [id_sector_corral], references: [id_sector_corral], onDelete: NoAction, onUpdate: NoAction)
  usuario                 usuario               @relation(fields: [registrado_por], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction)

  @@index([fecha_hora_medicion], map: "idx_registro_temperatura_fecha")
  @@index([id_sector_corral], map: "idx_registro_temperatura_sector")
}

model rol {
  id_rol      BigInt    @id @default(autoincrement())
  nombre_rol  String    @unique @db.VarChar(50)
  descripcion String?
  usuario     usuario[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model sector_corral {
  id_sector_corral     BigInt                 @id @default(autoincrement())
  id_corral            BigInt
  fila                 Int
  columna              Int
  codigo_sector        String                 @unique @db.VarChar(50)
  nido                 nido[]
  registro_temperatura registro_temperatura[]
  corral               corral                 @relation(fields: [id_corral], references: [id_corral], onDelete: Cascade, onUpdate: NoAction)

  @@unique([id_corral, fila, columna])
  @@index([id_corral], map: "idx_sector_corral_corral")
}

model tipo_alerta {
  id_tipo_alerta BigInt    @id @default(autoincrement())
  nombre         String    @unique @db.VarChar(100)
  descripcion    String?
  alertas        alertas[]
}

model tipo_corral {
  id_tipo_corral BigInt   @id @default(autoincrement())
  nombre         String   @unique @db.VarChar(50)
  descripcion    String?
  corral         corral[]
}

model tipo_depredador {
  id_tipo_depredador BigInt       @id @default(autoincrement())
  nombre             String       @unique @db.VarChar(100)
  descripcion        String?
  exhumacion         exhumacion[]
}

model usuario {
  id_usuario            BigInt                  @id @default(autoincrement())
  id_rol                BigInt
  email                 String                  @unique @db.VarChar(150)
  password_hash         String
  nombre                String                  @db.VarChar(100)
  apellido              String                  @db.VarChar(100)
  telefono              String?                 @db.VarChar(20)
  id_estado_usuario     BigInt
  fecha_creacion        DateTime                @default(now()) @db.Timestamp(6)
  alertas               alertas[]
  corral                corral[]
  eclosion              eclosion[]
  exhumacion            exhumacion[]
  nido                  nido[]
  recuperacion_password recuperacion_password[]
  registro_temperatura  registro_temperatura[]
  estado_usuario        estado_usuario          @relation(fields: [id_estado_usuario], references: [id_estado_usuario], onDelete: NoAction, onUpdate: NoAction)
  rol                   rol                     @relation(fields: [id_rol], references: [id_rol], onDelete: NoAction, onUpdate: NoAction)

  @@index([id_estado_usuario], map: "idx_usuario_estado")
  @@index([id_rol], map: "idx_usuario_rol")
}
